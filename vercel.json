{
    "functions": {
        "api/main.py": {
            "runtime": "@vercel/python@4.0.0"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/main.py"
        }
    ],
    "builds": [
        {
            "src": "api/main.py",
            "use": "@vercel/python"
        }
    ]
}
